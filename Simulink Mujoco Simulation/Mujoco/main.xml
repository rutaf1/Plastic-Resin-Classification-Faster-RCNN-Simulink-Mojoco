<mujoco model="main">
    <compiler meshdir="mesh/" texturedir="texture/"/>
    <!-- Naikkan batas kontak dan constraint -->
    <size nconmax="2000" njmax="4000" nstack="4000000"/>

    <!-- Buat solver lebih toleran terhadap banyak kontak -->
    <option timestep="0.001"
        iterations="200"
        tolerance="1e-8"
        integrator="implicit" viscosity="0.05"/>

    <include file="testfile.xml"/>

    <default>
        <geom contype="1" conaffinity="1"
              friction="0.8 0.3 0.1"
              solref="0.04 1" solimp="0.95 0.99 0.001 0.5 2"
              condim="3"/>
    </default>
    
    <visual>
        <rgba haze=".3 .3 .3 1"/>
    </visual>

    <asset>
        <texture name="texplane" type="2d" builtin="checker"
                 rgb1=".25 .25 .25" rgb2=".3 .3 .3"
                 width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
        <material name="matplane" reflectance="0.3" texture="texplane"
                  texrepeat="1 1" texuniform="true"/>
        <mesh name="Slider" file="Slider.obj" scale=".08 .08 .08"/>
        <mesh name="Rotary" file="Rotary.obj" scale="1 1 1"/>
    </asset>

    <worldbody>

        <geom name="floor" pos="0 0 0" size="0 0 1" type="plane" material="matplane" contype="2" conaffinity="1"/>
        <light directional="true" diffuse=".7 .7 .8" specular=".2 .2 .2"
               pos="0 0 4" dir="0 0 -1"/>
        <camera name="camera_dummy" mode="fixed" pos="0 0 20" euler="0 0 0" fovy="50"/>
        <camera name="camera" mode="fixed" pos="-8 0 13" euler="0 -45 90" fovy="50"/>

        <body name="Slider" pos="0 0 0">
            <geom mesh="Slider" type="mesh" contype="0" conaffinity="0" rgba="0.5 0.5 0.5 1"/>
            <geom name="wallLeft"     type="box" size="3 0.2 9"      pos="0 3.87 12"      rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="wallRight"    type="box" size="3 0.2 9"      pos="0 -3.87 12"     rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="wallBehind"   type="box" size="0.2 3.7 9"    pos="2.86 0 12"      rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="wallfront"    type="box" size="0.2 3.7 4"    pos="-2.86 0 16.5"   rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="sliderBottom"  type="box" size="0.2 3.7 3.6" pos="0.1 0 5.6"     euler="0 60 0"   rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <!-- sliderBottom1 dinonaktifkan: ujung atasnya menggantung di atas titik keluar sliderTop -> objek terjepit (wedge). Switchback asli hanya butuh sliderTop + sliderBottom. -->
            <!-- <geom name="sliderBottom1" type="box" size="0.2 3.7 2.7" pos="-1.8 0 8"      euler="0 60 0"   rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/> -->
            <geom name="sliderTop"     type="box" size="0.2 3.7 2.5" pos="-1.42 0 10.7"  euler="0 141 0"  rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="slider1"     type="box" size="0.2 3.7 2.5" pos="-4.3 0 23"  euler="0 141 0"  rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="slider2"     type="box" size="0.2 3.7 2.5" pos="4.3 0 23"  euler="0 -141 0"  rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="slider3"     type="box" size="3.7 0.2 2.5" pos="0 5.3 23"  euler="141 0 0"  rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
            <geom name="slider4"     type="box" size="3.7 0.2 2.5" pos="0 -5.3 23"  euler="-141 0 0"  rgba="1 0 0 0" contype="2" conaffinity="1" friction="0.001 0.001 0.001"/>
        </body>

        <body name="rotor" pos="1.4 0 9.5" euler="90 0 0">
            <joint name="hinge_rotor" type="hinge" axis="0 0 1" armature="100" damping="20"/>
            <geom type="cylinder" size="0.15 3.6" pos="0 0 0" rgba=".2 1 .2 1" contype="0" conaffinity="0"/>
            <body name="blade1" pos="0 0 0" euler="0 0 0">
                <geom type="box" size="0.05 0.6 3.6" pos="0 0.6 0" rgba=".2 1 .2 1"
